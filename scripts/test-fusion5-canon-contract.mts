ok("research logger normalizes invalid prediction phase", researchLog.includes("cleanPredictionPhase") && researchLog.includes('s === "followup"') && researchLog.includes('"clarification"'));

const pairInteractions = fs.readFileSync(path.join(root, "src/lib/fusion5/pair-interactions.ts"), "utf8");
ok("western pair aspect packet carries owner fields", pairInteractions.includes("aspects.push({ fromOwner: x.owner") && pairInteractions.includes("toOwner: y.owner"));
ok("western pair hidden contacts carry owner fields", pairInteractions.includes("hiddenContacts.push({ fromOwner: pa.owner") && pairInteractions.includes("toOwner: pb.owner"));

const ui = fs.readFileSync(path.join(root, "public/master-fusion.html"), "utf8");
for (const science of ["bazi", "qizheng", "ziwei", "western", "vedic"]) {
  ok(`ui registry has ${science}`, ui.includes(`${science}:`) && ui.includes(`data-sci-cb="' + s + '"'`));
}
ok("ui sends fusion5 thread history", ui.includes("history:priorHistory") && ui.includes("threadId:state.threadId") && ui.includes("rememberCompletedTurn"));
ok("ui hides prior history answers until show", ui.includes("data-hact=\"show-answer\"") && ui.includes("คำตอบถูกซ่อนไว้") && !/continueFromHistory\(row\)\{[\s\S]*?addMsg\('sifu'/.test(ui));

if (fail) {
  console.error(`FAIL fusion5 canon contract: ${fail}`);
  process.exit(1);
}
