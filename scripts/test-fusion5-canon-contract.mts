const parsePairPacket = (science: (typeof sciences)[number], births: [BirthData, BirthData]) => {
  const block = renderPairInteractionPacket(science, births, new Date("2026-07-01T05:00:00Z"));
  const start = block.indexOf("{");
  const end = block.lastIndexOf("}\n=== END_PAIR_INTERACTION_PACKET ===");
  if (start < 0 || end < 0) throw new Error(`cannot parse pair packet for ${science}`);
  return JSON.parse(block.slice(start, end + 1));
};

