[Unit]
Description=Hourkey durable Fusion AI worker
After=network-online.target docker.service hourkey-decode.service
Requires=docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/releases/current
Environment=NODE_ENV=production
EnvironmentFile=-/etc/hourkey/hourkey.env
ExecStart=/usr/bin/node /root/releases/current/scripts/workers/hourkey-worker.mjs hourkey-ai-fusion
Restart=always
RestartSec=5
TimeoutStopSec=980
KillSignal=SIGTERM

[Install]
WantedBy=multi-user.target
