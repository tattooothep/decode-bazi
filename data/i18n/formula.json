        "map_to_weight": {
          "-100..-50": "0..3.5",
          "-50..-20": "3.5..7.4",
          "-20..0": "7.4..10",
          "0..40": "10..14",
          "40..80": "14..18",
          "80..100": "18..20"
        }
      },
      "frontend_codes": [
        "三會",
        "三合",
        "六合",
        "六沖",
        "六害",
        "六破",
        "三刑",
