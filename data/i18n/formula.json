            "六破": -5,
            "六害": -4
          }
        },
        "position_modifier": {
          "day_branch": 1.5,
          "month_branch": 1.3,
          "hour_branch": 1.2,
          "year_branch": 1.0
        },
        "stack_modifier": {
          "day_only": 1.0,
          "day_year": 1.8,
          "day_luck_pillar": 2.0,
          "day_year_luck_pillar": 3.0
